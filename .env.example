# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Both of these are safe to expose in client-side code (protected by RLS)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key only — safe to expose in client-side code
# For development (localhost): use pk_test_... keys
# For production (HTTPS): use pk_live_... keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-test-publishable-key-here

# NEVER add VITE_STRIPE_SECRET_KEY here.
# The secret key must only live in server-side code (Supabase Edge Functions).
# For development: use sk_test_... keys
# For production: use sk_live_... keys (set in Supabase Dashboard)
